# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: override the Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+18665319438

# Set to "true" in production to validate Twilio request signatures
# VALIDATE_TWILIO_SIGNATURE=true

# Phone number to forward calls to if Claude fails (no + or dashes)
FALLBACK_PHONE=8174386142

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The ID from your sheet URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEETS_ID=your_google_sheet_id_here

# Paste the entire contents of your service account JSON key file as one line.
# Tip: cat your-key.json | jq -c . | pbcopy
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Name of the tab in your Google Sheet (default: "Call Records")
# GOOGLE_SHEET_TAB=Call Records

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
